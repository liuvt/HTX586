@page "/account/change-password"
@attribute [Authorize(Policy = "PasswordChangeAllowed")]
@inject NavigationManager Navigation

<PageTitle>Cập nhật mật khẩu</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Biểu mẫu cập nhật mật khẩu đang được hiển thị dưới dạng cửa sổ bắt buộc trên toàn bộ hệ thống.
    </MudAlert>
</MudContainer>
