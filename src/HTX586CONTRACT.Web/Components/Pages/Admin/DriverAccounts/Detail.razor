@page "/admin/driver-accounts/{UserId}"
@attribute [Authorize(Roles = "Owner,Admin")]
@inject IDriverAccountService DriverAccountService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDbContextFactory<ApplicationDbContext> Factory
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Chi tiết tài xế</PageTitle>
<PageHeader Title="Chi tiết tài xế" Subtitle="Xem thông tin tài khoản, hồ sơ, CCCD, GPLX, Company và chữ ký tài xế." />

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_detail is null)
{
    <MudAlert Severity="Severity.Error">Không tìm thấy tài xế.</MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="1">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Tên đăng nhập</MudText>
                <MudText Typo="Typo.h6">@_detail.UserName</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Họ và tên</MudText>
                <MudText>@_detail.FullName</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">CompanyProfile</MudText>
                <MudText>@Display(_detail.CompanyName)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Mã nhân viên</MudText>
                <MudText>@Display(_detail.EmployeeCode)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Số điện thoại</MudText>
                <MudText>@Display(_detail.PhoneNumber)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Email</MudText>
                <MudText>@Display(_detail.Email)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">CCCD</MudText>
                <MudText>@Display(_detail.CitizenId)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Ngày cấp CCCD</MudText>
                <MudText>@DisplayDate(_detail.CitizenIdIssuedDate)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Nơi cấp CCCD</MudText>
                <MudText>@Display(_detail.CitizenIdIssuedPlace)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Ngày sinh</MudText>
                <MudText>@DisplayDate(_detail.DateOfBirth)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Khu vực</MudText>
                <MudText>@Display(_detail.AreaCode)</MudText>
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.caption">Địa chỉ</MudText>
                <MudText>@Display(_detail.Address)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Số GPLX</MudText>
                <MudText>@Display(_detail.DriverLicenseNumber)</MudText>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudText Typo="Typo.caption">Hạng GPLX</MudText>
                <MudText>@Display(_detail.DriverLicenseClass)</MudText>
            </MudItem>

            <MudItem xs="12" md="2">
                <MudText Typo="Typo.caption">Ngày cấp GPLX</MudText>
                <MudText>@DisplayDate(_detail.DriverLicenseIssuedDate)</MudText>
            </MudItem>

            <MudItem xs="12" md="2">
                <MudText Typo="Typo.caption">Hết hạn GPLX</MudText>
                <MudText>@DisplayDate(_detail.DriverLicenseExpiryDate)</MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle1">Chữ ký cố định tài xế</MudText>

                @if (_detail.DriverSignatureIsActive && !string.IsNullOrWhiteSpace(_detail.DriverSignatureFileUrl))
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="my-2">
                        Chữ ký đang sử dụng.
                    </MudAlert>

                    <MudPaper Outlined="true" Class="pa-2 my-2">
                        <img src="@GetDriverSignatureUrl()"
                             style="max-width:260px; max-height:120px; object-fit:contain;" />
                    </MudPaper>

                    @if (_detail.DriverSignedAt.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Xác nhận lúc @_detail.DriverSignedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </MudText>
                    }
                }
                else
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-2">
                        Chưa có chữ ký đang sử dụng hoặc chữ ký cũ đã bị hủy.
                    </MudAlert>
                }
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle1">Trạng thái</MudText>

                <MudStack Row="true" Spacing="2">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@(_detail.IsActive ? Color.Success : Color.Error)">
                        @(_detail.IsActive ? "Tài khoản hoạt động" : "Tài khoản đã khóa")
                    </MudChip>

                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@GetSignatureStatusColor()">
                        @GetSignatureStatusText()
                    </MudChip>
                </MudStack>
            </MudItem>
        </MudGrid>

        @if (!string.IsNullOrWhiteSpace(_pendingAccountAction))
        {
            <MudAlert Severity="@PendingActionSeverity"
                      Variant="Variant.Outlined"
                      Class="mt-4">
                <MudText Typo="Typo.subtitle2">@PendingActionTitle</MudText>
                <MudText Typo="Typo.body2" Class="mt-1">@PendingActionMessage</MudText>

                <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-3">
                    <MudButton Variant="Variant.Text"
                               Disabled="_changingAccountState"
                               OnClick="CancelAccountAction">
                        Hủy
                    </MudButton>
                    <MudButton Color="@PendingActionColor"
                               Variant="Variant.Filled"
                               Disabled="_changingAccountState"
                               OnClick="ConfirmAccountActionAsync">
                        @(_changingAccountState ? "Đang xử lý..." : PendingActionConfirmText)
                    </MudButton>
                </MudStack>
            </MudAlert>
        }

        @if (_showResetPassword)
        {
            <MudPaper Class="pa-4 mt-4" Outlined="true">
                <MudText Typo="Typo.h6">Đặt lại mật khẩu tài xế</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Sau khi đặt lại, tài xế phải đổi mật khẩu tạm ở lần đăng nhập tiếp theo.
                </MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      @bind-Value="_newPassword"
                                      Label="Mật khẩu tạm mới"
                                      InputType="@(_showNewPassword ? InputType.Text : InputType.Password)"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(_showNewPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="@(() => _showNewPassword = !_showNewPassword)" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      @bind-Value="_confirmPassword"
                                      Label="Nhập lại mật khẩu tạm"
                                      InputType="@(_showNewPassword ? InputType.Text : InputType.Password)"
                                      Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Mật khẩu tối thiểu 6 ký tự và có ít nhất 1 chữ số.</MudText>
                <MudStack Row="true" Class="mt-3">
                    <MudButton Variant="Variant.Text" Disabled="_resettingPassword" OnClick="CancelResetPassword">Hủy</MudButton>
                    <MudSpacer />
                    <MudButton Color="Color.Warning"
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.LockReset"
                               Disabled="_resettingPassword"
                               OnClick="ResetPasswordAsync">
                        @(_resettingPassword ? "Đang cập nhật..." : "Xác nhận đặt lại mật khẩu")
                    </MudButton>
                </MudStack>
            </MudPaper>
        }

        <MudStack Row="true" Class="mt-4">
            <MudButton Variant="Variant.Outlined"
                       OnClick="@(() => Navigation.NavigateTo("/admin/driver-accounts"))">
                Quay lại
            </MudButton>

            <MudSpacer />

            @if (_detail.IsActive)
            {
                <MudButton Color="Color.Warning"
                           Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Lock"
                           Disabled="_changingAccountState"
                           OnClick="RequestLockAccount">
                    Khóa tạm thời
                </MudButton>
            }
            else
            {
                <MudButton Color="Color.Success"
                           Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.LockOpen"
                           Disabled="_changingAccountState"
                           OnClick="RequestUnlockAccount">
                    Mở khóa
                </MudButton>
            }

            <MudButton Color="Color.Error"
                       Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.PersonOff"
                       Disabled="_changingAccountState"
                       OnClick="RequestLeaveEmployment">
                Nghỉ việc
            </MudButton>

            <MudButton Color="Color.Warning"
                       Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.LockReset"
                       Disabled="@(_resettingPassword || _changingAccountState)"
                       OnClick="ShowResetPassword">
                Đặt lại mật khẩu
            </MudButton>

            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Edit"
                       OnClick="@(() => Navigation.NavigateTo($"/admin/driver-accounts/{UserId}/edit"))">
                Cập nhật
            </MudButton>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;

    private DriverAccountDetailDto? _detail;
    private bool _loading = true;
    private bool _showResetPassword;
    private bool _resettingPassword;
    private bool _showNewPassword;
    private string? _newPassword;
    private string? _confirmPassword;
    private string? _pendingAccountAction;
    private bool _changingAccountState;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        try
        {
            var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();

            _detail = await DriverAccountService.GetDetailAsync(UserId);

            if (_detail is not null && !auth.User.IsInRole("Owner"))
            {
                var currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

                await using var db = await Factory.CreateDbContextAsync();

                var allowedCompanyId = await db.Users.AsNoTracking()
                    .Where(x => x.Id == currentUserId && !x.IsDeleted && x.IsActive &&
                            x.CompanyProfile != null && x.CompanyProfile.IsActive && !x.CompanyProfile.IsDeleted)
                    .Select(x => x.CompanyProfileId)
                    .FirstOrDefaultAsync();

                if (_detail.CompanyProfileId != allowedCompanyId)
                {
                    Snackbar.Add("Admin chỉ được xem tài xế thuộc Công ty/văn phòng được gán.", Severity.Error);
                    Navigation.NavigateTo("/admin/driver-accounts");
                    _detail = null;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private Severity PendingActionSeverity => _pendingAccountAction == "leave"
        ? Severity.Error
        : Severity.Warning;

    private Color PendingActionColor => _pendingAccountAction == "leave"
        ? Color.Error
        : _pendingAccountAction == "unlock"
            ? Color.Success
            : Color.Warning;

    private string PendingActionTitle => _pendingAccountAction switch
    {
        "lock" => "Khóa tạm thời tài khoản tài xế?",
        "unlock" => "Mở khóa tài khoản tài xế?",
        "leave" => "Xác nhận tài xế nghỉ việc?",
        _ => string.Empty
    };

    private string PendingActionMessage => _pendingAccountAction switch
    {
        "lock" => "Tài xế sẽ không thể đăng nhập hoặc nhận hợp đồng mới. Xe đang được gán sẽ tự động chuyển về trạng thái chưa gán để giao cho tài xế khác. Hồ sơ và hợp đồng lịch sử vẫn được giữ nguyên.",
        "unlock" => "Tài xế có thể đăng nhập lại nhưng xe cũ không được tự động gán lại. Quản trị cần chọn xe phù hợp nếu muốn giao xe trở lại.",
        "leave" => "Tài khoản sẽ bị ẩn khỏi giao diện và không thể đăng nhập/nhận hợp đồng. Xe đang gán được giải phóng. Toàn bộ hồ sơ, chữ ký và hợp đồng lịch sử vẫn còn trong database.",
        _ => string.Empty
    };

    private string PendingActionConfirmText => _pendingAccountAction switch
    {
        "lock" => "Xác nhận khóa",
        "unlock" => "Xác nhận mở khóa",
        "leave" => "Xác nhận nghỉ việc",
        _ => "Xác nhận"
    };

    private void RequestLockAccount() => RequestAccountAction("lock");
    private void RequestUnlockAccount() => RequestAccountAction("unlock");
    private void RequestLeaveEmployment() => RequestAccountAction("leave");

    private void RequestAccountAction(string action)
    {
        if (_changingAccountState)
            return;

        _pendingAccountAction = action;
        _showResetPassword = false;
    }

    private void CancelAccountAction()
    {
        if (!_changingAccountState)
            _pendingAccountAction = null;
    }

    private async Task ConfirmAccountActionAsync()
    {
        if (string.IsNullOrWhiteSpace(_pendingAccountAction))
            return;

        try
        {
            _changingAccountState = true;

            switch (_pendingAccountAction)
            {
                case "lock":
                    await DriverAccountService.SetActiveAsync(UserId, false);
                    Snackbar.Add("Đã khóa tài khoản và giải phóng xe đang gán.", Severity.Success);
                    await OnParametersSetAsync();
                    break;

                case "unlock":
                    await DriverAccountService.SetActiveAsync(UserId, true);
                    Snackbar.Add("Đã mở khóa tài khoản. Xe cũ không được tự động gán lại.", Severity.Success);
                    await OnParametersSetAsync();
                    break;

                case "leave":
                    await DriverAccountService.DeleteAsync(UserId);
                    Snackbar.Add("Đã ghi nhận tài xế nghỉ việc và giải phóng xe. Dữ liệu lịch sử vẫn được giữ trong database.", Severity.Success);
                    Navigation.NavigateTo("/admin/driver-accounts");
                    break;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _changingAccountState = false;
            _pendingAccountAction = null;
        }
    }

    private void ShowResetPassword()
    {
        _newPassword = null;
        _confirmPassword = null;
        _showNewPassword = false;
        _showResetPassword = true;
    }

    private void CancelResetPassword()
    {
        if (_resettingPassword)
            return;

        _showResetPassword = false;
        _newPassword = null;
        _confirmPassword = null;
    }

    private async Task ResetPasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 6 || !_newPassword.Any(char.IsDigit))
        {
            Snackbar.Add("Mật khẩu phải có tối thiểu 6 ký tự và ít nhất 1 chữ số.", Severity.Warning);
            return;
        }

        if (!string.Equals(_newPassword, _confirmPassword, StringComparison.Ordinal))
        {
            Snackbar.Add("Mật khẩu nhập lại không khớp.", Severity.Warning);
            return;
        }

        try
        {
            _resettingPassword = true;
            await DriverAccountService.ResetPasswordAsync(UserId, _newPassword);
            Snackbar.Add("Đã đặt lại mật khẩu. Tài xế phải đổi mật khẩu khi đăng nhập lần tiếp theo.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _resettingPassword = false;
            _showResetPassword = false;
            _newPassword = null;
            _confirmPassword = null;
        }
    }

    private string? GetDriverSignatureUrl()
    {
        if (_detail is null)
            return null;

        if (!_detail.DriverSignatureIsActive)
            return null;

        if (string.IsNullOrWhiteSpace(_detail.DriverSignatureFileUrl))
            return null;

        var version = _detail.DriverSignedAt?.Ticks ?? DateTime.UtcNow.Ticks;

        return $"{_detail.DriverSignatureFileUrl}?v={version}";
    }

    private Color GetSignatureStatusColor()
    {
        if (_detail is null || string.IsNullOrWhiteSpace(_detail.DriverSignatureFileUrl))
            return Color.Warning;

        return _detail.DriverSignatureIsActive ? Color.Success : Color.Default;
    }

    private string GetSignatureStatusText()
    {
        if (_detail is null || string.IsNullOrWhiteSpace(_detail.DriverSignatureFileUrl))
            return "Chưa có chữ ký";

        return _detail.DriverSignatureIsActive ? "Chữ ký đang dùng" : "Chữ ký đã hủy";
    }

    private static string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string DisplayDate(DateTime? value) =>
        value.HasValue ? value.Value.ToString("dd/MM/yyyy") : "—";
}
